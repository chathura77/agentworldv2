# Copy this file to deploy/hostinger/.env on the VPS and adjust as needed.

# Path deployment for https://www.sarathchandra.com/agentworld/.
# Use "/" only if deploying to a dedicated subdomain such as
# https://agentworld.sarathchandra.com/.
AGENTWORLD_BASE=/agentworld/

# Local-only port used by the host reverse proxy.
AGENTWORLD_HOST_PORT=8080

# Optional image tag for local build output.
AGENTWORLD_IMAGE_TAG=hostinger
