# Copy this file to deploy/hostinger/.env on the VPS and adjust as needed.

# Recommended with the current sarathchandra.com DNS:
# https://agentworld.sarathchandra.com/
#
# Use "/agentworld/" only if the server that owns sarathchandra.com can proxy
# that path to this container.
AGENTWORLD_DOMAIN=agentworld.sarathchandra.com
AGENTWORLD_BASE=/
AGENTWORLD_HEALTH_PATH=/

# Local-only port used by the host reverse proxy. This intentionally avoids
# common local app ports so AgentWorld can run beside sites such as
# quantum-workbench.sarathchandra.com.
AGENTWORLD_HOST_PORT=18080

# Optional image tag for local build output.
AGENTWORLD_IMAGE_TAG=hostinger

# Optional TLS automation for bootstrap.sh. GitHub Actions can set these through
# repository variables/secrets for the first deployment.
AGENTWORLD_ENABLE_CERTBOT=0
AGENTWORLD_LETSENCRYPT_EMAIL=
